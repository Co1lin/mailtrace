# Copy to .env, fill in values, then `docker compose up -d`.
# All settings are read by pydantic-settings; the prefix is MAILTRACE_.

# --- IMb identity (issued by USPS Business Customer Gateway) ---
MAILTRACE_BARCODE_ID=0
MAILTRACE_SERVICE_TYPE_ID=40
MAILTRACE_MAILER_ID=123456

# --- USPS API (apis.usps.com) credentials ---
# https://developer.usps.com/
MAILTRACE_USPS_CLIENT_ID=replace-me
MAILTRACE_USPS_CLIENT_SECRET=replace-me

# --- Business Customer Gateway (legacy IV oauth - piece tracking) ---
MAILTRACE_BCG_USERNAME=
MAILTRACE_BCG_PASSWORD=

# --- Web app ---
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
MAILTRACE_SESSION_SECRET=replace-me

# Number of uvicorn workers behind the listening port.
MAILTRACE_WORKERS=2

# Mount the app under a subpath when behind a reverse proxy (e.g. /envelope).
# Leave empty for root.
MAILTRACE_ROOT_PATH=

# /usps_feed access control. Defaults are fail-closed:
# - With trusted_feed_ips=[] and feed_open=false (the defaults), every
#   request to /usps_feed is rejected with 403. This is the safe default;
#   there is no scenario where you want a public, unauthenticated endpoint
#   that writes into your Redis.
# - To enable the push feed, populate trusted_feed_ips with the IPs / CIDRs
#   USPS posts from. Example: ["56.0.0.0/8"]
# - Behind a reverse proxy, list the proxy's IP (or CIDR) in
#   trusted_proxies. Only requests whose immediate peer is in trusted_proxies
#   will have X-Forwarded-For honored when matching trusted_feed_ips.
# - feed_open=true disables the check entirely. Only sensible behind an
#   authenticated reverse proxy or on a private network.
MAILTRACE_TRUSTED_FEED_IPS=[]
MAILTRACE_TRUSTED_PROXIES=["127.0.0.1","::1"]
MAILTRACE_FEED_OPEN=false

# Timezone for facility timestamp display.
MAILTRACE_TIMEZONE=America/New_York

# Optional: change the host port that gets exposed on the docker host.
# Default binds 8084 to localhost; expose more broadly only intentionally.
MAILTRACE_BIND=127.0.0.1:8084
