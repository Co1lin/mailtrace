# mailtrace bootstrap env vars.
#
# This file holds ONLY the values the app needs to start at all. All
# operational config — including USPS API credentials — is set in the
# admin or per-user UI:
#   - /admin/                : users
#   - /admin/email           : SMTP server for digest emails
#   - /admin/ingest          : USPS push receiver (Basic Auth, gzip, archive)
#   - /admin/settings        : poll cadence
#   - /auth/account          : per-user USPS API, BCG, MID, notifications
#                              ↑ each user configures their own here

# === REQUIRED ===
# Signs the session cookie. Generate with:
#   python -c 'import secrets; print(secrets.token_hex(32))'
MAILTRACE_SESSION_SECRET=replace-me

# === Optional: defaults work for the bundled compose ===
# Persistent storage. SQLite at /data by default (the volume mount point;
# the Dockerfile pre-chowns it to uid 10001 = the mailtrace user).
# Note the FOUR slashes after `sqlite+aiosqlite:` — that's SQLAlchemy's
# absolute-path form. Three slashes would resolve relative to /app and
# the DB would be lost on every container recreate.
# For Postgres: postgresql+asyncpg://user:pass@host/db
MAILTRACE_DATABASE_URL=sqlite+aiosqlite:////data/mailtrace.db
# Redis (used as a token cache + serial allocator).
MAILTRACE_REDIS_URL=redis://mailtrace-redis:6379/0
# Mount under a subpath when behind a reverse proxy (e.g. /envelope). Empty = root.
MAILTRACE_ROOT_PATH=

# === Infrastructure (boot-time, rarely changed) ===
# Where /usps_feed archives raw POSTed JSON for audit / replay.
MAILTRACE_INGEST_ARCHIVE_DIR=/data/ingest_raw
# Reverse-proxy IPs whose X-Forwarded-For we trust for source-IP logging
# on /usps_feed (auth there is HTTP Basic Auth set in /admin/ingest).
MAILTRACE_TRUSTED_PROXIES=["127.0.0.1","::1"]

# === Server (uvicorn) ===
# Number of uvicorn worker processes. Each worker handles HTTP requests
# in parallel; CPU-bound work (PDF rendering) and I/O concurrency both
# scale with this. Multi-worker is safe: the background poll/archive/
# notification loop runs in every worker but is gated by a Redis-based
# leader lock so only one worker actually does the work at any moment
# (other workers stand by for failover if the leader dies).
# - 1: lowest memory; OK for single-user homelab.
# - 2 (default): comfortable for a small platform; PDFs in worker A
#   don't block validate-button calls handled by worker B.
# - 4+: only useful with many concurrent tenants.
MAILTRACE_WORKERS=2
# Timezone for facility timestamp display.
MAILTRACE_TIMEZONE=America/New_York
# Optional: change the host port that gets exposed on the docker host.
# Default binds 8084 to localhost; expose more broadly only intentionally.
MAILTRACE_BIND=127.0.0.1:8084
